# Vibe Coding Hackathon - environment template
#
# Copy this file to ".env" and fill in the keys your organisers provide for the day.
# ".env" is gitignored - NEVER commit it, and never paste real keys into chat.
#
# You only need the keys for the providers your app actually uses. Default to the
# small/fast model tier for every build (fast, cheap, good enough for a demo).

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
